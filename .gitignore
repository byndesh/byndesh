# ============================================
# BYND BD — .gitignore
# ============================================

# --- Dependencies ---
node_modules/
.pnpm-store/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build Output ---
.next/
out/
dist/
build/
.turbo/

# --- Environment ---
.env
.env.local
.env.production
.env.staging
.env.*.local

# --- IDE & Editor ---
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- AI Tooling (keep out of production repo) ---
.agents/
.claude/
scratch/
AGENTS.md
CLAUDE.md
skills-lock.json

# --- Debug & Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts

# --- Vercel ---
.vercel

# --- Testing ---
coverage/
.nyc_output/

# --- Prisma ---
/packages/database/src/generated/

# --- Misc ---
*.pem
*.key