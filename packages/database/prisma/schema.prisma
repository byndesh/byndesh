// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String
  password      String?
  image         String?
  phone         String?
  country       String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model CmsTrip {
  id                 String        @id @default(cuid())
  title              String
  titleBn            String?       @map("title_bn")
  slug               String        @unique
  excerpt            String?       @db.Text
  excerptBn          String?       @map("excerpt_bn") @db.Text
  description        String?       @db.Text
  descriptionBn      String?       @map("description_bn") @db.Text
  heroImage          String?       @map("hero_image")
  heroImageAlt       String?       @map("hero_image_alt")
  heroImageBlurhash  String?       @map("hero_image_blurhash")
  duration           Int
  nights             Int
  difficulty         String?       // Easy, Moderate, Challenging
  maxGroupSize       Int?          @map("max_group_size")
  itinerary          Json?         // Array of day objects
  includes           Json?         // Array of strings
  excludes           Json?         // Array of strings
  priceBDT           Decimal       @map("price_bdt") @db.Decimal(12, 2)
  priceUSD           Decimal?      @map("price_usd") @db.Decimal(12, 2)
  priceEUR           Decimal?      @map("price_eur") @db.Decimal(12, 2)
  status             ContentStatus @default(DRAFT)
  publishedAt        DateTime?     @map("published_at")
  featured           Boolean       @default(false)
  sortOrder          Int           @default(0) @map("sort_order")
  metaTitle          String?       @map("meta_title")
  metaDescription    String?       @map("meta_description")
  ogImage            String?       @map("og_image")
  createdBy          String?       @map("created_by")
  updatedBy          String?       @map("updated_by")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([slug])
  @@index([featured])
  @@map("cms_trips")
}

model CmsSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  action     String   // CREATE, UPDATE, DELETE, PUBLISH, LOGIN
  entityType String?  @map("entity_type") // Trip, Story, etc.
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
