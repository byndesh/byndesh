{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "tailwindCSS.experimental.classRegex": [
    ["clsx\\(([^)]*)\\)", "(?:'|\")([^']*)(?:'|\")"],
    ["cn\\(([^)]*)\\)", "(?:'|\")([^']*)(?:'|\")"]
  ]
}
