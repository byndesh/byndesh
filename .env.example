# ═══════════════════════════════════════════════════════════════════
# Beyndesh Monorepo — Environment Variables Template
# Copy to .env.local at the repo root or in each app directory.
# The root .env.local is shared via Turborepo pipeline.
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Supabase + Prisma) ────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → Database → Connection String → URI
# Transaction mode (pooled) — used by Prisma at runtime
DATABASE_URL="postgresql://postgres.YOURPROJECTREF:YOURPASSWORD@aws-0-us-east-1.pooler.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection — used by Prisma for migrations only
DIRECT_URL="postgresql://postgres:YOURPASSWORD@db.YOURPROJECTREF.supabase.co:5432/postgres"

# ─── Supabase Client ──────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECTREF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# WARNING: Never expose this key client-side — server only
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Authentication (NextAuth.js v5) ─────────────────────────────────────────
# CRITICAL: AUTH_SECRET must be identical across both apps (apps/web + apps/cms)
# and must NOT be empty. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret-32-chars-minimum"

# Google OAuth (optional) — leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App URLs ────────────────────────────────────────────────────────────────
# Development
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CMS_URL="http://localhost:3001"

# Production — update when deploying
# NEXT_PUBLIC_APP_URL="https://beyndesh.com"
# NEXT_PUBLIC_CMS_URL="https://cms.beyndesh.com"

# ─── On-demand Revalidation ───────────────────────────────────────────────────
# Secret used by CMS to call POST /api/revalidate on the web app
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET="replace-with-a-random-hex-secret"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxx"

# ─── Media Storage (Cloudflare R2) ───────────────────────────────────────────
# From: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="beyndesh-media"
# Public URL for the R2 bucket (after enabling public access or custom domain)
R2_PUBLIC_URL="https://media.beyndesh.com"

# ─── Keystatic CMS (Production) ──────────────────────────────────────────────
# Used when process.env.NODE_ENV === 'production'
GITHUB_OWNER="your-github-username"
GITHUB_REPO="your-repository-name"
KEYSTATIC_GITHUB_CLIENT_ID="from-github-oauth-app"
KEYSTATIC_GITHUB_CLIENT_SECRET="from-github-oauth-app"
KEYSTATIC_SECRET="random-string-for-session-encryption"

# ─── Search (Meilisearch) ────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ─── Payment ─────────────────────────────────────────────────────────────────
# Stripe (international cards)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SSLCommerz (Bangladesh local payment)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASS=""
SSLCOMMERZ_IS_LIVE="false"
